{
  "info": {
    "name": "Smart Assessment AI - Role-Based Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "JWT Auth with Role-Based Access Control (RBAC). After login, role is automatically assigned and determines API access.",
    "contact": {
      "name": "API Support",
      "url": "http://127.0.0.1:8000"
    }
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://127.0.0.1:8000"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "user_role",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "🔐 AUTHENTICATION & REGISTRATION",
      "description": "Simple login - role is assigned automatically during registration. No frontend selection needed.",
      "item": [
        {
          "name": "📝 Register as Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student_new\",\n  \"email\": \"student@example.com\",\n  \"password\": \"SecurePass@123\",\n  \"password_confirm\": \"SecurePass@123\",\n  \"first_name\": \"Ahmed\",\n  \"last_name\": \"Khan\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/auth/register/student/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "accounts", "auth", "register", "student", ""]
            }
          },
          "response": []
        },
        {
          "name": "📝 Register as Teacher",
          "request": {
            "method": "POST",
