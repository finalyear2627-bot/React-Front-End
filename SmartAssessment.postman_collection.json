{
  "info": {
    "name": "Smart Assessment AI - Backend APIs",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Standardized response format: all responses wrapped in {status, result}. JWT Auth, Accounts, Academics (Programs, Courses, PLO, CLO), Assessments."
  },
  "variable": [
    { "key": "base_url", "value": "http://127.0.0.1:8000" },
    { "key": "access_token", "value": "" },
    { "key": "refresh_token", "value": "" }
  ],
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Login (JWT)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var res = pm.response.json();",
                  "if (res.access) {",
                  "    pm.collectionVariables.set('access_token', res.access);",
                  "    pm.collectionVariables.set('refresh_token', res.refresh);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"administrator\",\n  \"password\": \"finalyear2627\"\n}"
            },
            "url": "{{base_url}}/api/auth/login/"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh_token}}\"\n}"
            },
            "url": "{{base_url}}/api/auth/refresh/"
          }
        }
      ]
    },
    {
      "name": "ACCOUNTS",
      "item": [
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/accounts/me/"
          }
        },
        {
          "name": "List Users (Admin Only)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/accounts/users/"
          }
        }
      ]
    },
    {
      "name": "ACADEMICS - PROGRAMS",
      "item": [
        {
          "name": "List Programs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/academics/programs/"
          }
        },
        {
          "name": "Create Program",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"BSCS\",\n  \"name\": \"BS Computer Science\"\n}"
            },
            "url": "{{base_url}}/api/academics/programs/"
          }
        },
        {
          "name": "Get Program",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/academics/programs/1/"
          }
        },
        {
          "name": "Update Program",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"BSCS\",\n  \"name\": \"BS Computer Science (Updated)\"\n}"
            },
            "url": "{{base_url}}/api/academics/programs/1/"
          }
        },
        {
          "name": "Delete Program",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/academics/programs/1/"
          }
        },
        {
          "name": "Bulk Upload Programs",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [{ "key": "file", "type": "file", "description": "CSV or Excel (.xlsx/.xls). Columns: code, name" }]
            },
            "url": "{{base_url}}/api/academics/programs/bulk-import/"
          }
        }
      ]
    },
    {
      "name": "ACADEMICS - COURSES",
      "item": [
        {
          "name": "List Courses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
