    {
      "name": "👤 ACCOUNTS - User Management",
      "description": "User management endpoints. Access controlled by role.",
      "item": [
        {
          "name": "👤 Get Current User (All Authenticated Users)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/accounts/me/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "accounts", "me", ""]
            },
            "description": "Get current logged-in user details including role."
          },
          "response": []
        },
        {
