            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"program\": 1,\n  \"code\": \"CMC111\",\n  \"name\": \"Programming Fundamentals\",\n  \"course_class\": \"CORE\",\n  \"credit_hours_theory\": 3,\n  \"credit_hours_lab\": 0\n}"
            },
            "url": "{{base_url}}/api/academics/courses/"
          }
        },
        {
          "name": "Get Course",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/academics/courses/1/"
          }
        },
        {
          "name": "Update Course",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"program\": 1,\n  \"code\": \"CMC111\",\n  \"name\": \"Programming Fundamentals (Updated)\",\n  \"course_class\": \"CORE\",\n  \"credit_hours_theory\": 3,\n  \"credit_hours_lab\": 0\n}"
            },
            "url": "{{base_url}}/api/academics/courses/1/"
          }
        },
        {
          "name": "Delete Course",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": "{{base_url}}/api/academics/courses/1/"
          }
        },
        {
          "name": "Bulk Upload Courses",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "description": "CSV or Excel (.xlsx/.xls). Columns: code, name, course_class (CORE/GER/ELECTIVE), credit_hours_theory, credit_hours_lab, program_code, pre_requisites (comma-separated), co_requisites (comma-separated)"
                }
              ]
            },
            "url": "{{base_url}}/api/academics/courses/bulk-import/"
          }
        }
      ]
    },
