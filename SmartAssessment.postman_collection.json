            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"teacher_new\",\n  \"email\": \"teacher@example.com\",\n  \"password\": \"SecurePass@123\",\n  \"password_confirm\": \"SecurePass@123\",\n  \"first_name\": \"Hassan\",\n  \"last_name\": \"Ahmed\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/auth/register/teacher/",
