          },
          "response": []
        },
        {
          "name": "🔑 Login - Simple (Any Role)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var jsonData = pm.response.json();",
                  "  pm.environment.set('access_token', jsonData.access);",
                  "  pm.environment.set('refresh_token', jsonData.refresh);",
                  "  pm.environment.set('user_role', jsonData.user.role);",
                  "  console.log('Login successful! Role: ' + jsonData.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"student1\",\n  \"password\": \"Student@123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/accounts/auth/login/",
              "protocol": "http",
              "host": ["127", "0", "0", "1"],
              "port": "8000",
              "path": ["api", "accounts", "auth", "login", ""]
            },
            "description": "Simple login endpoint. No role selection. Backend assigns role automatically based on user account type."
          },
          "response": []
        },
